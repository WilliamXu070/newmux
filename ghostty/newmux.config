# Ghostty test profile for newmux.
#
# Add this file through Ghostty's `config-file` option, or run:
#   scripts/open-newmux-ghostty.sh
#
# Ghostty docs: `command` runs a command for new terminal surfaces, and
# `keybind = trigger=action` can send text/control bytes to the child process.

title = Newmux Dev
confirm-close-surface = false
command = /bin/zsh
input = raw:exec /Users/williamxu/Desktop/Projects/newmux/scripts/start-newmux-fresh.sh\r
shell-integration = none

# Override Chrome-style reopen-tab for this test profile.
# Sends tmux prefix Ctrl-B followed by uppercase T, which is bound in
# config/newmux-dev.tmux.conf as the future restore hook.
keybind = cmd+shift+t=text:\x02T

# Test tmux copy mode without manually pressing the tmux prefix.
keybind = cmd+shift+h=text:\x02H

# Make Shift+Enter behave like Option+Enter for terminal apps that use
# Meta+Enter as "insert newline" instead of "submit".
keybind = alt+enter=text:\x1b\r
keybind = shift+enter=text:\x1b\r
