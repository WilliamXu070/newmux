# Temporary Ghostty profile for Newmux scrolling experiments.

title = Newmux Scroll Test
confirm-close-surface = false
command = /bin/zsh
input = raw:exec /Users/williamxu/Desktop/Projects/newmux/scripts/start-newmux-scroll-test.sh\r
shell-integration = none

keybind = cmd+shift+h=text:\x02H
keybind = cmd+shift+t=text:\x02T
keybind = alt+enter=text:\x1b\r
keybind = shift+enter=text:\x1b\r
